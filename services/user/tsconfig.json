{
  "compilerOptions": {
    /* Basic Options */
      "target": "es2019",
      "module": "ESNext",         
"moduleResolution": "node",
      "outDir": "./dist",
      "rootDir": "./src",
      "strict": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "skipLibCheck": true
  }
}
